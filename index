<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>1RM Calculator - Old School Iron</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #121212;
            -webkit-tap-highlight-color: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar { height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #1a1a1a; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }

        input[type=range] {
            -webkit-appearance: none;
            background: #1f2937;
            height: 8px;
            border-radius: 4px;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 24px;
            width: 24px;
            border-radius: 50%;
            background: #dc2626;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        /* Manifest for PWA */
        link[rel="manifest"] {
            display: none;
        }
    </style>
</head>
<body class="text-white selection:bg-red-900 overflow-x-hidden">

    <!-- Top Navigation -->
    <div class="bg-[#b30000] p-4 flex justify-between items-center font-bold sticky top-0 z-10 shadow-lg">
        <div class="flex-1 text-center flex items-center justify-center">
            <span>OLD SCHOOL IRON</span>
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
    </div>

    <div class="flex text-sm font-bold border-b border-gray-800">
        <div class="flex-1 text-center py-4 border-b-2 border-red-600 text-red-500 uppercase tracking-tighter">1RM Calculator</div>
        <div class="flex-1 text-center py-4 text-gray-500 uppercase tracking-tighter">Pullup Calculator</div>
    </div>

    <main class="p-5 max-w-2xl mx-auto mb-10">
        <p class="text-gray-400 text-sm mb-8 leading-relaxed">
            Drag the weight and reps sliders to the highest weight you have lifted. Your One Rep Max will appear below.
        </p>

        <!-- Unit Selection -->
        <section class="mb-10">
            <h3 class="font-bold uppercase tracking-wider mb-1 text-sm">Unit of Measurement</h3>
            <p class="text-gray-500 text-[10px] mb-4 uppercase">Select your preferred weight unit.</p>
            
            <div class="space-y-4">
                <label class="flex items-center space-x-3 cursor-pointer group" onclick="setUnit('kg')">
                    <div id="radio-kg" class="w-6 h-6 rounded-full border-2 flex items-center justify-center border-red-600">
                        <div class="w-3 h-3 rounded-full bg-red-600"></div>
                    </div>
                    <span class="text-gray-200 font-medium">Metric (Kg)</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group" onclick="setUnit('lb')">
                    <div id="radio-lb" class="w-6 h-6 rounded-full border-2 flex items-center justify-center border-gray-600">
                        <div class="w-3 h-3 rounded-full bg-transparent"></div>
                    </div>
                    <span class="text-gray-200 font-medium">Imperial (lb)</span>
                </label>
            </div>
        </section>

        <!-- Weight Slider -->
        <section class="mb-10">
            <h3 class="font-bold uppercase tracking-wider mb-1 text-sm">Weight Lifted</h3>
            <div class="flex flex-col mt-4">
                <div class="text-white font-extrabold text-2xl mb-4 text-center">
                    <span id="weight-display">100</span> <span id="unit-label" class="text-gray-500 text-lg">kg</span>
                </div>
                <div class="flex items-center space-x-4">
                    <button onclick="adjustWeight(-1)" class="w-12 h-12 flex-shrink-0 rounded-full border-2 border-red-600 flex items-center justify-center text-red-600 active:bg-red-600 active:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 12H4"></path></svg>
                    </button>
                    <input id="weight-slider" type="range" min="2.5" max="400" step="2.5" value="100" class="w-full">
                    <button onclick="adjustWeight(1)" class="w-12 h-12 flex-shrink-0 rounded-full border-2 border-red-600 flex items-center justify-center text-red-600 active:bg-red-600 active:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                    </button>
                </div>
            </div>
        </section>

        <!-- Reps Slider -->
        <section class="mb-10">
            <h3 class="font-bold uppercase tracking-wider mb-1 text-sm">Reps Completed</h3>
            <div class="flex flex-col mt-4">
                <div id="reps-display" class="text-white font-extrabold text-2xl mb-4 text-center">5 reps</div>
                <div class="flex items-center space-x-4">
                    <button onclick="adjustReps(-1)" class="w-12 h-12 flex-shrink-0 rounded-full border-2 border-red-600 flex items-center justify-center text-red-600 active:bg-red-600 active:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 12H4"></path></svg>
                    </button>
                    <input id="reps-slider" type="range" min="1" max="15" step="1" value="5" class="w-full">
                    <button onclick="adjustReps(1)" class="w-12 h-12 flex-shrink-0 rounded-full border-2 border-red-600 flex items-center justify-center text-red-600 active:bg-red-600 active:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                    </button>
                </div>
            </div>
        </section>
    </main>

    <!-- Results Section -->
    <div class="bg-[#1a1a1a] p-6 pb-24 rounded-t-[2.5rem] border-t border-gray-800 shadow-2xl">
        <div class="max-w-2xl mx-auto">
            <div class="mb-8">
                <h3 class="text-gray-500 font-bold uppercase tracking-widest text-xs mb-2">Your One Rep Max</h3>
                <div class="text-6xl font-black text-white tracking-tighter">
                    <span id="orm-display">113</span><span class="text-2xl font-bold text-red-600 ml-2" id="orm-unit">kg</span>
                </div>
            </div>

            <!-- Tables -->
            <div id="tables-container"></div>
        </div>
    </div>

    <script>
        const REP_COEFFICIENTS = {
            1: 1.000, 2: 0.950, 3: 0.926, 4: 0.900, 5: 0.882,
            6: 0.858, 7: 0.824, 8: 0.809, 9: 0.779, 10: 0.760,
            11: 0.745, 12: 0.730, 13: 0.710, 14: 0.695, 15: 0.681
        };

        const STANDARDS = [95, 90, 85, 80, 75, 70, 65, 60, 55, 50];
        const OLD_SCHOOL = [102.5, 97.5, 92.5, 87.5, 82.5, 77.5, 72.5, 67.5, 62.5, 57.5];
        const EST_REPS = [1, 3, 5, 8, 10, 12, 15];

        let state = {
            unit: 'kg',
            weight: 100,
            reps: 5,
            orm: 0
        };

        const weightSlider = document.getElementById('weight-slider');
        const repsSlider = document.getElementById('reps-slider');

        function setUnit(u) {
            if (state.unit === u) return;
            state.unit = u;
            
            // Update UI Radios
            document.getElementById('radio-kg').className = `w-6 h-6 rounded-full border-2 flex items-center justify-center ${u === 'kg' ? 'border-red-600' : 'border-gray-600'}`;
            document.getElementById('radio-kg').children[0].className = `w-3 h-3 rounded-full ${u === 'kg' ? 'bg-red-600' : 'bg-transparent'}`;
            document.getElementById('radio-lb').className = `w-6 h-6 rounded-full border-2 flex items-center justify-center ${u === 'lb' ? 'border-red-600' : 'border-gray-600'}`;
            document.getElementById('radio-lb').children[0].className = `w-3 h-3 rounded-full ${u === 'lb' ? 'bg-red-600' : 'bg-transparent'}`;
            
            // Update Slider Constraints
            if (u === 'lb') {
                weightSlider.min = 5;
                weightSlider.max = 800;
                weightSlider.step = 5;
                state.weight = Math.round((state.weight * 2.20462) / 5) * 5;
            } else {
                weightSlider.min = 2.5;
                weightSlider.max = 400;
                weightSlider.step = 2.5;
                state.weight = Math.round((state.weight / 2.20462) / 2.5) * 2.5;
            }
            weightSlider.value = state.weight;
            calculate();
        }

        function adjustWeight(dir) {
            const step = state.unit === 'kg' ? 2.5 : 5;
            state.weight = Math.max(parseFloat(weightSlider.min), Math.min(parseFloat(weightSlider.max), state.weight + (dir * step)));
            weightSlider.value = state.weight;
            calculate();
        }

        function adjustReps(dir) {
            state.reps = Math.max(1, Math.min(15, state.reps + dir));
            repsSlider.value = state.reps;
            calculate();
        }

        weightSlider.addEventListener('input', (e) => {
            state.weight = parseFloat(e.target.value);
            calculate();
        });

        repsSlider.addEventListener('input', (e) => {
            state.reps = parseInt(e.target.value);
            calculate();
        });

        function calculate() {
            const coeff = REP_COEFFICIENTS[state.reps] || 0.681;
            state.orm = Math.round(state.weight / coeff);

            document.getElementById('weight-display').innerText = state.weight;
            document.getElementById('unit-label').innerText = state.unit;
            document.getElementById('reps-display').innerText = state.reps + " reps";
            document.getElementById('orm-display').innerText = state.orm;
            document.getElementById('orm-unit').innerText = state.unit;

            renderTables();
        }

        function renderTables() {
            const container = document.getElementById('tables-container');
            container.innerHTML = `
                ${createTable("1RM Percentages", STANDARDS, STANDARDS.map(p => Math.round(state.orm * (p/100) * 2)/2))}
                ${createTable("Old School Percentages", OLD_SCHOOL, OLD_SCHOOL.map(p => Math.round(state.orm * (p/100) * 2)/2))}
                ${createTable("Est. Weight by Reps", EST_REPS, EST_REPS.map(r => Math.round(state.orm * REP_COEFFICIENTS[r] * 2)/2), "Reps")}
            `;
        }

        function createTable(title, headers, values, headerLabel = "%") {
            return `
                <h4 class="text-white font-bold uppercase text-[10px] tracking-widest mt-10 mb-4 opacity-50">${title}</h4>
                <div class="overflow-x-auto custom-scrollbar pb-2">
                    <div class="min-w-max">
                        <div class="flex border-b border-gray-800 pb-2 mb-2">
                            <div class="w-16 text-[10px] font-bold text-gray-600 uppercase pt-1">${headerLabel}</div>
                            ${headers.map(h => `<div class="w-16 text-center text-xs font-bold text-gray-400">${h}${headerLabel === '%' ? '' : ''}</div>`).join('')}
                        </div>
                        <div class="flex">
                            <div class="w-16 text-[10px] font-bold text-gray-600 uppercase">WT</div>
                            ${values.map(v => `<div class="w-16 text-center text-sm font-bold text-white">${v}</div>`).join('')}
                        </div>
                    </div>
                </div>
            `;
        }

        // Initial Calc
        calculate();

        // Register Service Worker for Offline (Self-contained dummy worker)
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => {
            const blob = new Blob([`
              self.addEventListener('fetch', function(event) {
                event.respondWith(fetch(event.request).catch(() => caches.match(event.request)));
              });
            `], { type: 'text/javascript' });
            const swUrl = URL.createObjectURL(blob);
            navigator.serviceWorker.register(swUrl).then(registration => {
              console.log('SW registered:', registration);
            }).catch(error => {
              console.log('SW registration failed:', error);
            });
          });
        }
    </script>
</body>
</html>
